#!/usr/bin/env python3
"""
Web Search Tool - DuckDuckGo based, no API key required
Usage: web-search "query" [--limit N] [--type web|news|images|videos] [--extract]
"""

import sys
import json
import argparse
from ddgs import DDGS


def search_web(query: str, limit: int = 10, region: str = "wt-wt", safesearch: str = "on"):
    """Perform a web search using DuckDuckGo"""
    try:
        ddgs = DDGS()
        results = list(ddgs.text(query, region=region, safesearch=safesearch, max_results=limit))
        return results
    except Exception as e:
        return {"error": str(e)}


def search_news(query: str, limit: int = 10):
    """Perform a news search using DuckDuckGo"""
    try:
        ddgs = DDGS()
        results = list(ddgs.news(query, max_results=limit))
        return results
    except Exception as e:
        return {"error": str(e)}


def search_images(query: str, limit: int = 10):
    """Perform an image search using DuckDuckGo"""
    try:
        ddgs = DDGS()
        results = list(ddgs.images(query, max_results=limit))
        return results
    except Exception as e:
        return {"error": str(e)}


def search_videos(query: str, limit: int = 10):
    """Perform a video search using DuckDuckGo"""
    try:
        ddgs = DDGS()
        results = list(ddgs.videos(query, max_results=limit))
        return results
    except Exception as e:
        return {"error": str(e)}


def extract_url(url: str):
    """Extract content from a URL"""
    try:
        from ddgs import DDGS
        ddgs = DDGS()
        # Use text search with site: operator to get info about the URL
        results = list(ddgs.text(f"site:{url}", max_results=1))
        return results
    except Exception as e:
        return {"error": str(e)}


def main():
    parser = argparse.ArgumentParser(description="Web search using DuckDuckGo")
    parser.add_argument("query", help="Search query or URL")
    parser.add_argument("--limit", "-n", type=int, default=10, help="Number of results (default: 10)")
    parser.add_argument("--type", "-t", choices=["web", "news", "images", "videos"], default="web", help="Search type")
    parser.add_argument("--region", "-r", default="wt-wt", help="Region code (default: wt-wt)")
    parser.add_argument("--safesearch", "-s", choices=["on", "moderate", "off"], default="on", help="Safe search level")
    parser.add_argument("--extract", "-e", action="store_true", help="Extract content from URL")
    parser.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    args = parser.parse_args()
    
    # Check if query is a URL
    is_url = args.query.startswith("http://") or args.query.startswith("https://")
    
    if args.extract or is_url:
        if is_url and not args.extract:
            # If it's a URL without --extract flag, just extract it
            results = extract_url(args.query)
        else:
            results = extract_url(args.query)
    elif args.type == "news":
        results = search_news(args.query, args.limit)
    elif args.type == "images":
        results = search_images(args.query, args.limit)
    elif args.type == "videos":
        results = search_videos(args.query, args.limit)
    else:
        results = search_web(args.query, args.limit, args.region, args.safesearch)
    
    # Format output
    if args.json:
        print(json.dumps(results, indent=2))
    else:
        if isinstance(results, dict) and "error" in results:
            print(f"Error: {results['error']}", file=sys.stderr)
            sys.exit(1)
        
        if not results:
            print("No results found.")
            return
        
        for i, result in enumerate(results, 1):
            if args.type in ["images", "videos"]:
                print(f"{i}. {result.get('title', 'No title')}")
                print(f"   URL: {result.get('url', result.get('image', 'No URL'))}")
            else:
                print(f"{i}. {result.get('title', 'No title')}")
                print(f"   {result.get('href', result.get('url', 'No URL'))}")
                if result.get('body'):
                    print(f"   {result.get('body')[:200]}...")
            print()


if __name__ == "__main__":
    main()
